generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AskStatus {
  PENDING
  FULFILLED
}

enum TermUserRole {
  ADMIN
  MEMBER
  VISITOR
}

model Member {
  id        String     @id @default(cuid())
  name      String
  asks      Ask[]
  termUsers TermUser[]
}

model Ask {
  id        String    @id @default(cuid())
  title     String
  status    AskStatus @default(PENDING)
  ownerId   String?
  owner     Member?   @relation(fields: [ownerId], references: [id])
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Upload {
  id           String   @id @default(cuid())
  fileUrl      String
  fileType     String
  detectedType String?
  createdAt    DateTime @default(now())
}

model Referral {
  id           String    @id @default(cuid())
  fromName     String
  toName       String
  description  String?
  sourceType   String
  chapterType  String
  status       String?
  temperature  String?
  phone        String?
  email        String?
  address      String?
  comments     String?
  amount       Float?
  date         DateTime?
  fromMemberId String?
  toMemberId   String?
  uploadId     String
  createdAt    DateTime  @default(now())
}

model Term {
  id        String     @id @default(cuid())
  name      String
  startDate DateTime
  endDate   DateTime
  isActive  Boolean    @default(false)
  activeKey String?    @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  termUsers TermUser[]

  @@index([isActive])
  @@index([startDate, endDate])
}

model TermUser {
  userId    String
  termId    String
  role      TermUserRole
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  user      Member       @relation(fields: [userId], references: [id], onDelete: Cascade)
  term      Term         @relation(fields: [termId], references: [id], onDelete: Cascade)

  @@id([userId, termId])
  @@index([termId, role])
}
